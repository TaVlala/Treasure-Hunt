# ============================================================
# TREASURE HUNT — Environment Variables
# Copy this file to apps/server/.env and fill in your values.
# Never commit the actual .env file — it contains secrets.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3001

# --- Database ---
# PostgreSQL connection string with PostGIS extension
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/treasure_hunt

# --- JWT Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-64-char-random-secret-here
JWT_REFRESH_SECRET=your-different-64-char-random-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Mapbox ---
# Get from: https://account.mapbox.com/access-tokens/
# Server token (keep private — used for server-side map operations)
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here
# Public tokens below are safe to expose in frontend code
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# --- Cloudflare R2 (File Storage) ---
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=treasure-hunt
# Your R2 bucket's public URL (set up custom domain or use r2.dev subdomain)
R2_PUBLIC_URL=https://cdn.yourdomain.com

# --- Stripe (Payments) ---
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# Public key is safe to expose in frontend
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# URL sponsors are redirected to after leaving the Stripe Billing Portal
STRIPE_BILLING_PORTAL_RETURN_URL=https://yourapp.com/sponsor/dashboard

# --- Resend (Email) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# "From" address for all outgoing emails (must be a verified Resend domain)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Redis (BullMQ job queues) ---
# Required for background jobs (analytics, email, cleanup). Optional in dev.
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379

# --- Sentry (Error Tracking & Performance Monitoring) ---
# Get from: https://sentry.io → Settings → Projects → your project → Client Keys (DSN)
# Leave blank in local development — Sentry is disabled when this is unset.
SENTRY_DSN=https://your_public_key@o0.ingest.sentry.io/your_project_id
# Fraction of requests to capture as performance traces (0.0–1.0). Keep low in prod to control quota.
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- CORS ---
# Comma-separated list of origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Frontend URLs (used by admin app) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# --- Mobile App URLs (used by Expo app) ---
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1
