{
  "expo": {
    "name": "Treasure Hunt",
    "slug": "treasure-hunt",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "treasure-hunt",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tavlala.treasurehunt"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f59e0b"
      },
      "package": "com.tavlala.treasurehunt"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f59e0b",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Treasure Hunt to use your location to find clues nearby."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Treasure Hunt to access the camera to scan QR clues."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
