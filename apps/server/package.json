{
  "name": "@treasure-hunt/server",
  "version": "1.0.0",
  "private": true,
  "description": "Treasure Hunt REST API — Express + TypeScript backend serving all mobile and admin requests",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.46.0",
    "@treasure-hunt/shared": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "express-rate-limit": "^8.3.1",
    "fast-levenshtein": "^3.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.15.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.9",
    "@types/pino-http": "^5.8.4",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
