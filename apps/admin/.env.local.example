# Copy this file to .env.local and fill in the values.

# URL of the backend API server (no trailing slash)
# Used in client components and browser-side fetches
NEXT_PUBLIC_API_URL=http://localhost:3001

# Same URL but not exposed to the browser — used in server components
# In production this can be an internal/private URL
API_URL=http://localhost:3001

# Mapbox public token — get one at https://account.mapbox.com/access-tokens/
# Required for the interactive clue placement map on the hunt detail page
NEXT_PUBLIC_MAPBOX_TOKEN=
